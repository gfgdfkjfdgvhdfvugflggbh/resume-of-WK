{
  "rewrites": [
    { "source": "/api/config", "destination": "/api/config.js" },
    { "source": "/api/auth-email", "destination": "/api/auth-email.js" },
    { "source": "/api/auth-session", "destination": "/api/auth-session.js" },
    { "source": "/api/me", "destination": "/api/me.js" },
    { "source": "/api/orders", "destination": "/api/orders.js" },
    { "source": "/api/order-claim", "destination": "/api/order-claim.js" },
    { "source": "/api/resume-english", "destination": "/api/resume-english.js" },
    { "source": "/api/admin-confirm", "destination": "/api/admin-confirm.js" },
    { "source": "/api/quota-consume", "destination": "/api/quota-consume.js" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(app|admin|firebase-auth|firebase-config).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
