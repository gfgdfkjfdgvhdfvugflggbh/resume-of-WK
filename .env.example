# 仅填写到本地 .env 或生产密钥管理系统；不要把真实私钥提交到 Git。
DEMO_MODE=false
PORT=4173
PUBLIC_BASE_URL=https://your-domain.example
ADMIN_SECRET=replace-with-a-long-random-secret

# Firebase Authentication（Web 配置可在 Firebase 控制台 → 项目设置 → 你的应用中复制）
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Firebase Admin 服务账号 JSON 的本机绝对路径；JSON 文件不要放进 Git 仓库。
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json
# 在 Cloud Run 等已提供应用默认凭证的环境可改为 true，并省略上面的 JSON 路径。
FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=false

XIANYU_ITEM_URL=https://www.goofish.com/item/your-item
XIANYU_SINGLE_URL=https://www.goofish.com/item/single-download
XIANYU_BASIC_URL=https://www.goofish.com/item/basic-membership
XIANYU_PRO_URL=https://www.goofish.com/item/pro-membership

# 普通个人闲鱼首发保持 false；申请到正式微信/支付宝商户后才打开。
DIRECT_PAYMENT_ENABLED=false

# 微信支付 Native
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_MERCHANT_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=https://your-domain.example/api/payments/webhook/wechat

# 支付宝
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_OR_CERT_PATH=
ALIPAY_NOTIFY_URL=https://your-domain.example/api/payments/webhook/alipay
ALIPAY_RETURN_URL=https://your-domain.example/payment/complete

# 短信服务
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# 微信网站登录
WECHAT_LOGIN_APP_ID=
WECHAT_LOGIN_APP_SECRET=
WECHAT_LOGIN_REDIRECT_URI=https://your-domain.example/api/auth/wechat/callback

# Sign in with Apple
APPLE_TEAM_ID=
APPLE_SERVICES_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_REDIRECT_URI=https://your-domain.example/api/auth/apple/callback

# 联调回调；正式环境必须使用微信/支付宝官方证书验签
PAYMENT_WEBHOOK_SECRET=
